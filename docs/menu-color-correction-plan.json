    "created_from_audit": true,
    "objective": "Corrigir a mistura estranha entre dourado, branco puro e bege no cardapio sem alterar regra de negocio.",
    "business_logic_policy": {
      "change_business_logic": false,
      "change_state": false,
      "change_handlers": false,
      "change_api_calls": false,
      "change_queries_or_mutations": false,
