      "features/menu/components/menu-shell.tsx",
      "features/menu/components/product-detail-shell.tsx",
      "features/menu/components/checkout-shell.tsx",
      "components/customer/customer-flow-header.tsx",
      "app/globals.css",
      "tailwind.config.ts"
    ]
  },
  "diagnosis": {
    "short_answer": "O cardapio esta misturando um fundo grande dourado/bege hardcoded com cards brancos, superficies off-white, chips dourados e o token global primary tambem dourado. O dourado aparece como fundo, texto, badge, botao, preco e glow, enquanto o branco aparece como card e overlay. Falta uma paleta semantica dedicada para o cardapio.",
    "root_causes": [
      "Nao existe familia de tokens menu-* para o fluxo publico do cardapio.",
      "O tema global claro ja usa primary dourado e accent dourado claro.",
      "A tela principal adiciona um gradiente dourado/bege hardcoded por cima do tema global.",
      "Cards e botoes usam bg-white, bg-white/80, bg-white/90 e bg-white/96 em cima do fundo dourado.",
      "bg-accent e text-primary sao usados em muitos pontos, entao tudo fica dourado ao mesmo tempo.",
      "O header do fluxo do cliente adiciona bg-arabesque e radial-gradient dourado hardcoded.",
      "Os componentes do fluxo usam background global, card global e primary global de forma diferente entre lista, detalhe e checkout."
    ],
    "desired_direction": "Criar uma paleta dedicada menu-* com base neutra quente, superficies marfim, texto escuro, bordas discretas e dourado apenas como acento. O CTA principal deve usar uma cor escura premium para parar de competir com preco e badges."
  },
