# Supabase — copie esses valores do painel: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=cole_a_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=cole_a_service_role_key_aqui

# Storage
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=produtos

# URL publica do site (sem barra no final)
NEXT_PUBLIC_SITE_URL=https://casadosheik.com

# Usado apenas uma vez para criar o primeiro admin (script: npm run bootstrap:admin)
BOOTSTRAP_ADMIN_EMAIL=admin@seurestaurante.com
BOOTSTRAP_ADMIN_PASSWORD=senha_forte_aqui
